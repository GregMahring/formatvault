# formatvault environment variables
#
# IMPORTANT (SOC2 / ADR-0001): This is a client-side only application.
# Environment variables prefixed with VITE_ are bundled into the client JS
# and are PUBLIC — never put secrets, API keys, or tokens here.
#
# All variables in this file are safe examples only.

# Public app URL (used for OG meta tags in SSR)
VITE_APP_URL=http://localhost:5173

# Plausible Analytics domain (safe — public domain name only)
# VITE_PLAUSIBLE_DOMAIN=formatvault.com
