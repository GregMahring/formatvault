{
  "name": "formatvault",
  "version": "0.1.0",
  "description": "Privacy-first developer tool for formatting, validating, and converting data formats",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy",
    "pages:dev": "wrangler pages dev ./build/client",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/cloudflare": "^7.13.2",
    "@react-router/dev": "^7.13.2",
    "@tailwindcss/vite": "^4.2.1",
    "@uiw/react-codemirror": "^4.25.4",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "dompurify": "^3.3.1",
    "fast-xml-parser": "^5.5.9",
    "jose": "^6.1.3",
    "js-base64": "^3.7.8",
    "js-md5": "^0.8.3",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "jsonpath-plus": "^10.4.0",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.3",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.13.2",
    "smol-toml": "^1.6.0",
    "sql-formatter": "^15.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "to-json-schema": "^0.2.5",
    "vite-tsconfig-paths": "^6.1.1",
    "zustand": "^5.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@playwright/test": "^1.51.0",
    "@streamparser/json": "^0.0.22",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/js-md5": "^0.8.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/to-json-schema": "^0.2.4",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "@vitest/coverage-v8": "^3.1.0",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^3.1.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.5.3",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.3.1",
    "vitest": "^3.1.0",
    "wrangler": "^4.78.0"
  }
}
